{
    "version": 2,
    "builds": [
        {
            "src": "./build/**",
            "use": "@vercel/static"
       },
        {
            "src": "api/main.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/main.py"
        },
        {
            "src": "/(.*)",
            "dest": "./build/$1"
        }
    ]
}